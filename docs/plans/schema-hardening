  groupId       String?
  optionId      String?
  @@index([orderIntentId])
}

model OrderIntentModifier {
  id            String      @id @default(cuid())
  orderIntentId String
  orderIntent   OrderIntent @relation(fields: [orderIntentId], references: [id], onDelete: Cascade)
  groupName     String
  optionName    String
  groupId       String?
  optionId      String?
  @@index([orderIntentId])

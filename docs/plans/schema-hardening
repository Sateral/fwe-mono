## CRITICAL — Implement First (Money & Data Correctness)

### 1. Replace JSON blobs with junction tables

**Risk: HIGH. Currently `substitutions Json?` and `modifiers Json?` exist on `Order`, `OrderIntent`, `CartItem`, and `CheckoutSessionItem`. These are unvalidated, unqueryable, and will corrupt the prep manifest if malformed.**

Add the following models to the Prisma schema:

```prisma
model OrderSubstitution {
  id         String  @id @default(cuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  groupName  String  // snapshot of name at order time — preserved even if meal config changes
  optionName String  // snapshot of name at order time
  groupId    String? // soft reference — nullable because the group may be deleted later
  optionId   String? // soft reference — nullable because the option may be deleted later
  @@index([orderId])
}

model OrderModifier {
  id         String  @id @default(cuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  groupName  String
  optionName String
  groupId    String?
  optionId   String?
  @@index([orderId])
}

model CartItemSubstitution {
  id         String   @id @default(cuid())
  cartItemId String
  cartItem   CartItem @relation(fields: [cartItemId], references: [id], onDelete: Cascade)
  groupName  String
  optionName String
  groupId    String?
  optionId   String?
  @@index([cartItemId])
}

model CartItemModifier {
  id         String   @id @default(cuid())
  cartItemId String
  cartItem   CartItem @relation(fields: [cartItemId], references: [id], onDelete: Cascade)
  groupName  String
  optionName String
  groupId    String?
  optionId   String?
  @@index([cartItemId])
}

model OrderIntentSubstitution {
  id            String      @id @default(cuid())
  orderIntentId String
  orderIntent   OrderIntent @relation(fields: [orderIntentId], references: [id], onDelete: Cascade)
  groupName     String

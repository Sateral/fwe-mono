{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": ["WEB_BASE_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "generate": {
      "dependsOn": ["^generate"],
      "inputs": ["$TURBO_DEFAULT$", "prisma/**"],
      "outputs": ["src/generated/prisma/**"],
      "env": ["DATABASE_URL"]
    },
    "migrate": {
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "migrate:deploy": {
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "seed": {
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "studio": {
      "cache": false,
      "env": ["DATABASE_URL"],
      "persistent": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Meal {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  ingredients String?  @db.Text
  imageUrl    String?
  isFeatured  Boolean  @default(false)

  // Default pricing & macros
  price    Decimal @default(0) @db.Decimal(10, 2)
  calories Int   @default(0)
  protein  Int   @default(0)
  carbs    Int   @default(0)
  fat      Int   @default(0)
  fiber    Int   @default(0)

  substitutionGroups SubstitutionGroup[]
  modifierGroups     ModifierGroup[]
  tags               DietaryTag[]
  orders             Order[]
  orderIntents       OrderIntent[]
  checkoutSessionItems CheckoutSessionItem[]
  rotations          WeeklyRotation[]    @relation("RotationMeals")
  rotationPeriods    RotationPeriod[]    @relation("RotationPeriodMeals")
  cartItems          CartItem[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([isFeatured])
}

model SubstitutionGroup {
  id      String               @id @default(cuid())
  name    String // e.g., "Carb Source", "Protein Source"
  mealId  String
  meal    Meal                 @relation(fields: [mealId], references: [id], onDelete: Cascade)
  options SubstitutionOption[]

  // Soft-reference back-links from order-level junction tables
  orderSubstitutions OrderSubstitution[]

  @@index([mealId])
}

model SubstitutionOption {
  id              String            @id @default(cuid())
  name            String // e.g., "White Rice", "Brown Rice", "Quinoa"
  isDefault       Boolean           @default(false)
  priceAdjustment Decimal           @default(0) @db.Decimal(10, 2) // e.g., +1.50 for quinoa
  calorieAdjust   Int               @default(0)
  proteinAdjust   Int               @default(0)
  carbsAdjust     Int               @default(0)
  fatAdjust       Int               @default(0)
  fiberAdjust     Int               @default(0)
  groupId         String
  group           SubstitutionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  // Soft-reference back-links from order-level junction tables
  orderSubstitutions OrderSubstitution[]

  @@index([groupId])
}

model ModifierGroup {
  id           String           @id @default(cuid())
  name         String // "Select Base", "Add-Ons"
  type         ModifierType // SINGLE_SELECT, MULTI_SELECT
  minSelection Int              @default(0)
  maxSelection Int?
  mealId       String
  meal         Meal             @relation(fields: [mealId], references: [id], onDelete: Cascade)
  options      ModifierOption[]

  // Soft-reference back-links from order-level junction tables
  orderModifiers OrderModifier[]

  @@index([mealId])
}

model ModifierOption {
  id              String        @id @default(cuid())
  name            String
  extraPrice      Decimal       @default(0) @db.Decimal(10, 2)
  modifierGroupId String
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  // Soft-reference back-links from order-level junction tables
  orderModifiers OrderModifier[]

  @@index([modifierGroupId])
}

model DietaryTag {
  id    String @id @default(cuid())
  name  String @unique // "Vegan", "Gluten-Free", "High Protein"
  color String @default("#000000")
  icon  String @default("circle")
  meals Meal[]
}

model Order {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  settlementMethod SettlementMethod @default(STRIPE)

  // Order-time customer snapshot
  customerName            String?
  customerEmail           String?
  customerPhone           String?
  customerDeliveryAddress String?
  customerDeliveryCity    String?
  customerDeliveryPostal  String?
  customerDeliveryNotes   String? @db.Text
  customerIsGuest         Boolean @default(false)

  // Meal reference
  mealId   String?
  meal     Meal?  @relation(fields: [mealId], references: [id], onDelete: SetNull)
  mealName String // Snapshot of meal name at order time for archive purposes

  // Pricing
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2) // Price per meal at time of order
  totalAmount Decimal @db.Decimal(10, 2) // Final amount charged

  // Customizations (relational junction tables — soft-reference pattern)
  substitutions OrderSubstitution[]
  modifiers     OrderModifier[]
  notes         String? @db.Text

  // Fulfillment
  deliveryMethod DeliveryMethod @default(DELIVERY)
  pickupLocation String?

  // Payment & fulfillment status
  paymentStatus         PaymentStatus     @default(PENDING)
  fulfillmentStatus     FulfillmentStatus @default(NEW)
  currency              String            @default("cad")
  paidAt                DateTime?
  refundedAt            DateTime?
  refundAmount          Decimal           @default(0) @db.Decimal(10, 2)
  stripeSessionId       String?
  stripePaymentIntentId String?
  stripeChargeId        String?
  stripeRefundId        String?
  stripeBalanceTransactionId String?

  orderIntentId String? @unique
  orderIntent   OrderIntent? @relation("OrderIntentToOrder", fields: [orderIntentId], references: [id])
  referralUse   ReferralUse?

  // Direct link to checkout session (Item 3)
  checkoutSessionId String?
  checkoutSession   CheckoutSession? @relation(fields: [checkoutSessionId], references: [id])

  // Multi-meal transaction grouping (Item 4)
  orderGroupId String?
  orderGroup   OrderGroup? @relation(fields: [orderGroupId], references: [id])

  paymentEvents        PaymentEvent[]
  fulfillmentChanges   FulfillmentStatusChange[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Meal Rotation Linking
  rotationId String
  rotation   WeeklyRotation @relation(fields: [rotationId], references: [id])

  // Performance indexes
  @@index([userId])          // Fast user order history lookup
  @@index([paymentStatus])   // Fast payment status filtering
  @@index([fulfillmentStatus]) // Fast fulfillment status filtering
  @@index([createdAt])       // Fast date-range queries
  @@index([rotationId])      // Fast rotation-based queries
  @@index([mealId])          // Fast meal-based aggregations
  @@index([customerEmail])
  @@index([stripeSessionId])
  @@index([stripePaymentIntentId])
  @@index([checkoutSessionId])
  @@index([orderGroupId])
}

// ============================================
// Order Customization Junction Tables (Soft-Reference Pattern)
// ============================================
//
// Snapshot strings (groupName, optionName) are immutable — they preserve
// the exact text the customer saw at order time even if the catalog option
// is later renamed or deleted.
//
// Nullable FK IDs (groupId, optionId) enable clean aggregation queries
// for the prep manifest without JSON parsing. They are set to NULL via
// onDelete: SetNull if the referenced option is removed.
// ============================================

model OrderSubstitution {
  id         String              @id @default(cuid())
  orderId    String
  order      Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  groupName  String              // Immutable snapshot
  optionName String              // Immutable snapshot
  groupId    String?
  group      SubstitutionGroup?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  optionId   String?
  option     SubstitutionOption? @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([groupId])
  @@index([optionId])
}

model OrderModifier {
  id         String          @id @default(cuid())
  orderId    String
  order      Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  groupName  String          // Immutable snapshot
  optionName String          // Immutable snapshot (one row per selected option)
  groupId    String?
  group      ModifierGroup?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  optionId   String?
  option     ModifierOption? @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([groupId])
  @@index([optionId])
}

// ============================================
// Cart-Level Customization Tables (plain string IDs, no FK)
// ============================================
//
// Cart/Checkout/Intent items store groupId and optionId as plain strings
// (not foreign keys) since these are transient/snapshot records that don't
// need referential integrity enforcement. Only Order-level junction tables
// carry actual FK relations for prep manifest aggregation.
// ============================================

model CartItemSubstitution {
  id         String   @id @default(cuid())
  cartItemId String
  cartItem   CartItem @relation(fields: [cartItemId], references: [id], onDelete: Cascade)
  groupName  String
  optionName String
  groupId    String?  // Reference ID, not FK
  optionId   String?  // Reference ID, not FK

  @@index([cartItemId])
}

model CartItemModifier {
  id         String   @id @default(cuid())
  cartItemId String
  cartItem   CartItem @relation(fields: [cartItemId], references: [id], onDelete: Cascade)
  groupName  String
  optionName String   // One row per selected option
  groupId    String?
  optionId   String?

  @@index([cartItemId])
}

model IntentSubstitution {
  id            String      @id @default(cuid())
  orderIntentId String
  orderIntent   OrderIntent @relation(fields: [orderIntentId], references: [id], onDelete: Cascade)
  groupName     String
  optionName    String
  groupId       String?
  optionId      String?

  @@index([orderIntentId])
}

model IntentModifier {
  id            String      @id @default(cuid())
  orderIntentId String
  orderIntent   OrderIntent @relation(fields: [orderIntentId], references: [id], onDelete: Cascade)
  groupName     String
  optionName    String
  groupId       String?
  optionId      String?

  @@index([orderIntentId])
}

model CheckoutItemSubstitution {
  id                    String              @id @default(cuid())
  checkoutSessionItemId String
  checkoutSessionItem   CheckoutSessionItem @relation(fields: [checkoutSessionItemId], references: [id], onDelete: Cascade)
  groupName             String
  optionName            String
  groupId               String?
  optionId              String?

  @@index([checkoutSessionItemId])
}

model CheckoutItemModifier {
  id                    String              @id @default(cuid())
  checkoutSessionItemId String
  checkoutSessionItem   CheckoutSessionItem @relation(fields: [checkoutSessionItemId], references: [id], onDelete: Cascade)
  groupName             String
  optionName            String
  groupId               String?
  optionId              String?

  @@index([checkoutSessionItemId])
}

// ============================================
// Order Group (Multi-Meal Transaction)
// ============================================

model OrderGroup {
  id                    String           @id @default(cuid())
  checkoutSessionId     String           @unique
  checkoutSession       CheckoutSession  @relation(fields: [checkoutSessionId], references: [id])
  stripeSessionId       String?          @unique
  stripePaymentIntentId String?          @unique
  stripeChargeId        String?
  totalAmount           Decimal          @db.Decimal(10, 2)
  currency              String           @default("cad")
  orders                Order[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
}

// ============================================
// Fulfillment Status Audit Log (Item 5)
// ============================================

model FulfillmentStatusChange {
  id          String            @id @default(cuid())
  orderId     String
  order       Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus  FulfillmentStatus
  toStatus    FulfillmentStatus
  changedById String?
  changedBy   User?             @relation("FulfillmentChanges", fields: [changedById], references: [id], onDelete: SetNull)
  reason      String?           @db.Text
  createdAt   DateTime          @default(now())

  @@index([orderId])
  @@index([createdAt])
}

enum ModifierType {
  SINGLE_SELECT
  MULTI_SELECT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum FulfillmentStatus {
  NEW
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum OrderIntentStatus {
  CREATED
  SESSION_CREATED
  PAID
  FAILED
  EXPIRED
  CANCELLED
}

// Item 10: Retired PUBLISHED — only DRAFT and ARCHIVED remain
enum RotationStatus {
  DRAFT
  ARCHIVED
}

enum DeliveryMethod {
  DELIVERY
  PICKUP
}

enum SettlementMethod {
  STRIPE
  MEAL_PLAN_CREDITS
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
  ABANDONED
  MERGED
}

enum GuestSource {
  CHECKOUT
  MANUAL
  IMPORT
  OTHER
}

enum MealPlanStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum MealPlanLedgerEvent {
  PURCHASE
  REDEMPTION
  PLAN_STARTED
  PLAN_RENEWED
  ORDER_REDEEMED
  ORDER_REVERSED
  MANUAL_ADJUSTMENT
  REFERRAL_BONUS
  EXPIRATION
}

enum FlavorProfileInvolvement {
  HANDS_ON
  HANDS_OFF
}

enum OnboardingStatus {
  PENDING
  SKIPPED
  COMPLETED
}

enum ReferralCodeStatus {
  ACTIVE
  DISABLED
}

// Item 12: Price source for cart items
enum PriceSource {
  STANDARD        // Calculated from meal base + mods + subs
  MEAL_PLAN        // $0 via credit redemption
  DISCOUNT         // Manual or coupon discount
  MANUAL_OVERRIDE  // Admin-set price
}

model RotationPeriod {
  id        String         @id @default(cuid())
  key       String         @unique
  name      String
  status    RotationStatus @default(DRAFT)
  rotations WeeklyRotation[]
  meals     Meal[]         @relation("RotationPeriodMeals")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

// ============================================
// Weekly Rotation System
// ============================================

model WeeklyRotation {
  id          String         @id @default(cuid())
  weekStart   DateTime       // Thursday 00:00 America/Toronto (fulfillment cycle start; Thu-Wed)
  weekEnd     DateTime       // Following Wednesday 23:59:59.999 America/Toronto
  orderCutoff DateTime       // That Thursday 14:59:59.999 (ordering closes for this cycle)
  status      RotationStatus @default(DRAFT)
  rotationPeriodId String?
  rotationPeriod   RotationPeriod? @relation(fields: [rotationPeriodId], references: [id], onDelete: SetNull)
  meals       Meal[]         @relation("RotationMeals")
  orders      Order[]
  cartItems   CartItem[]
  orderIntents OrderIntent[]
  checkoutSessionItems CheckoutSessionItem[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([weekStart])
  @@index([status])
  @@index([rotationPeriodId])
}

// ============================================
// Cart + Checkout Pipeline
// ============================================
//
// Lifecycle:  Cart  ->  CheckoutSession (snapshot)  ->  OrderIntent (per-item)  ->  Order (paid)
//
// Cart / CartItem         - Live, mutable shopping cart. Customers edit freely.
// CheckoutSession / Item  - Immutable snapshot taken at checkout start. Protects
//                           against cart edits between "pay" click and webhook.
// OrderIntent             - One per cart item. Tracks pre-payment status through
//                           the Stripe lifecycle (CREATED -> SESSION_CREATED -> PAID).
// Order                   - Final paid record, created by the webhook handler.
//
// Why the redundancy? If a customer edits their cart after clicking "pay" but
// before the payment webhook fires, the snapshot ensures the webhook creates
// orders matching what was actually charged.
// ============================================

model Cart {
  id               String           @id @default(cuid())
  clientRequestId  String?          @unique
  userId           String
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  settlementMethod SettlementMethod @default(STRIPE)
  status           CartStatus       @default(ACTIVE)
  items            CartItem[]
  checkoutSessions CheckoutSession[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([userId])
  @@index([status])
  @@index([userId, status])
}

model CartItem {
  id           String          @id @default(cuid())
  cartId       String
  cart         Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  mealId       String
  meal         Meal            @relation(fields: [mealId], references: [id], onDelete: Cascade)
  rotationId   String?
  rotation     WeeklyRotation? @relation(fields: [rotationId], references: [id], onDelete: SetNull)
  quantity     Int
  unitPrice    Decimal         @db.Decimal(10, 2)

  // Customizations (relational junction tables)
  substitutions CartItemSubstitution[]
  modifiers     CartItemModifier[]
  notes         String?         @db.Text

  // Item 12: Price source tracking
  priceSource  PriceSource     @default(STANDARD)

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([cartId])
  @@index([mealId])
  @@index([rotationId])
}

// ============================================
// Dead Letter Queue for Failed Orders
// ============================================

/// Stores failed order creation attempts for admin recovery.
/// When a Stripe payment succeeds but order creation fails,
/// the order data is stored here for manual or automated retry.
/// (Separate from the checkout pipeline -- this is a dead-letter queue.)
model FailedOrder {
  id String @id @default(cuid())

  // Stripe identifiers for lookup
  stripeSessionId       String  @unique
  stripePaymentIntentId String?

  // Customer info
  customerEmail String?
  customerName  String?

  // Order data (JSON blob of the full order request)
  orderData Json

  // Error tracking
  errorMessage String  @db.Text
  errorCode    String?

  // Recovery status
  status     FailedOrderStatus @default(PENDING)
  retryCount Int               @default(0)

  // Item 6: Admin notification tracking
  adminNotifiedAt DateTime?

  // Timestamps
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?
  resolvedBy String? // Admin user ID who resolved it

  @@index([status])
  @@index([createdAt])
}

// ============================================
// Order Intent (Pre-Payment)
// ============================================

/// Pre-payment intent for a single cart item.
/// Created during checkout, before the Stripe session.
/// Tracks status from CREATED -> SESSION_CREATED -> PAID/FAILED.
model OrderIntent {
  id String @id @default(cuid())

  clientRequestId String? @unique

  userId String
  user   User   @relation(fields: [userId], references: [id])

  mealId String?
  meal   Meal?  @relation(fields: [mealId], references: [id], onDelete: SetNull)

  rotationId String
  rotation   WeeklyRotation @relation(fields: [rotationId], references: [id])

  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  totalAmount Decimal @db.Decimal(10, 2)
  currency    String @default("cad")
  settlementMethod SettlementMethod @default(STRIPE)

  // Customizations (relational junction tables)
  substitutions IntentSubstitution[]
  modifiers     IntentModifier[]
  notes         String? @db.Text

  deliveryMethod DeliveryMethod @default(DELIVERY)
  pickupLocation String?

  status OrderIntentStatus @default(CREATED)

  order Order? @relation("OrderIntentToOrder")
  checkoutSessionItems CheckoutSessionItem[]
  paymentEvents PaymentEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([rotationId])
}

/// Immutable snapshot of cart state at checkout initiation.
/// One per checkout attempt; items mirror the cart at the moment "Pay" was clicked.
model CheckoutSession {
  id String @id @default(cuid())

  clientRequestId String? @unique

  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  settlementMethod SettlementMethod @default(STRIPE)
  status           OrderIntentStatus @default(CREATED)

  customerEmail String
  customerName  String?

  deliveryMethod DeliveryMethod @default(DELIVERY)
  pickupLocation String?

  stripeSessionId       String? @unique
  stripePaymentIntentId String? @unique
  stripeChargeId        String?
  stripeBalanceTransactionId String?

  items CheckoutSessionItem[]

  // Item 3: Orders linked to this checkout session
  orders Order[]

  // Item 4: Order group for multi-meal transactions
  orderGroup OrderGroup?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cartId])
  @@index([userId])
  @@index([status])
}

/// Single line item within a checkout snapshot.
/// Points back to both the OrderIntent and the Meal for audit trail.
model CheckoutSessionItem {
  id String @id @default(cuid())

  checkoutSessionId String
  checkoutSession   CheckoutSession @relation(fields: [checkoutSessionId], references: [id], onDelete: Cascade)

  orderIntentId String @unique
  orderIntent   OrderIntent @relation(fields: [orderIntentId], references: [id], onDelete: Cascade)

  mealId String?
  meal   Meal?  @relation(fields: [mealId], references: [id], onDelete: SetNull)

  mealName     String
  mealSlug     String
  mealImageUrl String?

  rotationId String
  rotation   WeeklyRotation @relation(fields: [rotationId], references: [id])

  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  totalAmount Decimal @db.Decimal(10, 2)
  currency    String @default("cad")

  // Customizations (relational junction tables)
  substitutions CheckoutItemSubstitution[]
  modifiers     CheckoutItemModifier[]
  notes         String? @db.Text

  deliveryMethod DeliveryMethod @default(DELIVERY)
  pickupLocation String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([checkoutSessionId])
  @@index([mealId])
  @@index([rotationId])
}

// ============================================
// Payment Event Log
// ============================================

model PaymentEvent {
  id String @id @default(cuid())

  provider  String  @default("stripe")
  eventId   String  @unique
  eventType String
  livemode  Boolean @default(false)
  payload   Json

  orderIntentId String?
  orderIntent   OrderIntent? @relation(fields: [orderIntentId], references: [id])

  orderId String?
  order   Order? @relation(fields: [orderId], references: [id])

  processedAt DateTime?
  errorMessage String?
  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([createdAt])
}

enum FailedOrderStatus {
  PENDING // Awaiting retry or manual resolution
  RETRYING // Currently being retried
  RESOLVED // Successfully recovered
  ABANDONED // Marked as unrecoverable (e.g., refunded)
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  emailVerified Boolean   @default(false)
  image         String?
  sessions      Session[]
  accounts      Account[]

  orders           Order[]
  orderIntents     OrderIntent[]
  carts            Cart[]
  checkoutSessions CheckoutSession[]
  mealPlan         MealPlan?
  flavorProfile    FlavorProfile?
  ownedReferralCode ReferralCode? @relation("ReferralCodeOwner")
  referralUse      ReferralUse?   @relation("ReferralUseReferredUser")
  stripeCustomerId String? @unique @map(name: "stripe_customer_id")

  // Fulfillment audit trail (Item 5)
  fulfillmentChanges FulfillmentStatusChange[] @relation("FulfillmentChanges")

  isGuest           Boolean     @default(false)
  guestSource       GuestSource?
  guestSourceId     String?     @unique
  guestMetadata     Json?
  mergedIntoUserId  String?
  mergedIntoUser    User?       @relation("GuestAccountMerge", fields: [mergedIntoUserId], references: [id], onDelete: SetNull)
  mergedGuestUsers  User[]      @relation("GuestAccountMerge")
  mergedAt          DateTime?

  // Profile completion for onboarding
  profileComplete  Boolean          @default(false)
  onboardingStatus OnboardingStatus @default(PENDING)
  phone            String?
  deliveryAddress  String?
  deliveryCity     String?
  deliveryPostal   String?
  deliveryNotes    String?  @db.Text

  banned     Boolean?  @default(false)
  banReason  String?
  banExpires DateTime?

  @@index([isGuest])
  @@index([mergedIntoUserId])
  @@map("user")
}

model MealPlan {
  id              String                  @id @default(cuid())
  userId          String                  @unique
  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          MealPlanStatus          @default(ACTIVE)
  weeklyCreditCap Int
  startsAt        DateTime                @default(now())
  endsAt          DateTime?
  autoRenew       Boolean                 @default(true)

  // Item 9: Price/billing snapshot
  priceAtPurchase  Decimal?               @db.Decimal(10, 2)
  billingInterval  String?                // e.g. "weekly", "monthly"
  billingCurrency  String                 @default("cad")

  windowUsages    MealPlanWindowUsage[]
  creditLedger    MealPlanCreditLedger[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([status])
}

model MealPlanWindowUsage {
  id          String   @id @default(cuid())
  mealPlanId  String
  mealPlan    MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  windowStart DateTime
  windowEnd   DateTime
  creditsUsed Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([mealPlanId, windowStart])
  @@index([windowStart])
  @@index([windowEnd])
}

model MealPlanCreditLedger {
  id           String              @id @default(cuid())
  mealPlanId   String
  mealPlan     MealPlan            @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  eventType    MealPlanLedgerEvent
  creditDelta  Int
  referenceType String?
  referenceId  String?
  note         String?             @db.Text
  createdAt    DateTime            @default(now())

  @@index([mealPlanId, createdAt])
  @@index([mealPlanId, referenceType, referenceId])
  @@index([eventType])
}

model FlavorProfile {
  id          String                     @id @default(cuid())
  userId      String                     @unique
  user        User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  goals       String[]
  restrictions String[]                  @default([])
  preferences  String[]                  @default([])
  involvement FlavorProfileInvolvement
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
}

model ReferralCode {
  id          String             @id @default(cuid())
  ownerUserId String             @unique
  ownerUser   User               @relation("ReferralCodeOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  code        String             @unique
  status      ReferralCodeStatus @default(ACTIVE)
  maxUses     Int?
  uses        ReferralUse[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status])
}

model ReferralUse {
  id             String       @id @default(cuid())
  referralCodeId String
  referralCode   ReferralCode @relation(fields: [referralCodeId], references: [id], onDelete: Restrict)
  referredUserId String       @unique
  referredUser   User         @relation("ReferralUseReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)
  orderId        String?      @unique
  order          Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())

  @@index([referralCodeId])
}

enum Role {
  USER
  ADMIN
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@index([identifier])
  @@map("verification")
}

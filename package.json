{
  "name": "fwe-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "db:generate": "turbo run generate --filter=@fwe/db",
    "db:push": "cd packages/db && bunx prisma db push",
    "db:push:reset": "cd packages/db && bunx prisma db push --force-reset --accept-data-loss",
    "db:reset": "cd packages/db && bunx prisma migrate reset --force",
    "db:migrate": "turbo run migrate --filter=@fwe/db",
    "db:migrate:deploy": "turbo run migrate:deploy --filter=@fwe/db",
    "db:seed": "turbo run seed --filter=@fwe/db",
    "db:studio": "turbo run studio --filter=@fwe/db",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:watch": "turbo watch test"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "shadcn": "^4.1.0",
    "turbo": "^2.8.1",
    "typescript": "5.9.2",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}

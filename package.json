{
  "name": "fwe-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "db:generate": "turbo run generate --filter=@fwe/db",
    "db:migrate": "turbo run migrate --filter=@fwe/db",
    "db:migrate:deploy": "turbo run migrate:deploy --filter=@fwe/db",
    "db:seed": "turbo run seed --filter=@fwe/db",
    "db:studio": "turbo run studio --filter=@fwe/db",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.1",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
